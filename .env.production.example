# Paste these into Vercel → Project → Settings → Environment Variables.
# Mark each one as Production (and Preview if you want PR deployments).

# ── Postgres ─────────────────────────────────────────────────────────
# From Vercel → Storage → your Postgres → ".env.local" tab. Copy
# POSTGRES_URL (it exposes the pooler URL) as DATABASE_URL.
DATABASE_URL=

# ── Clerk ────────────────────────────────────────────────────────────
# From clerk.com → your instance → API Keys.
CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
# Webhook signing secret — set up a Webhook endpoint in Clerk pointing at
# https://<your-app>.vercel.app/api/webhooks/clerk and copy the signing
# secret it generates. Needed for user/org provisioning; skip for first
# smoke test (sign-in will still work).
CLERK_WEBHOOK_SIGNING_SECRET=

# ── QuickBooks Online (optional) ─────────────────────────────────────
# Only required if you want to exercise the QBO integration. Register an
# app at https://developer.intuit.com → My Apps, add the redirect URI
# below, and copy client id/secret.
QBO_CLIENT_ID=
QBO_CLIENT_SECRET=
QBO_REDIRECT_URI=https://<your-app>.vercel.app/api/quickbooks/callback
QBO_ENV=sandbox
