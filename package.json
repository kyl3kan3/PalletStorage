{
  "name": "wms",
  "private": true,
  "version": "0.0.0",
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "db:generate": "pnpm --filter @wms/db db:generate",
    "db:migrate": "pnpm --filter @wms/db db:migrate",
    "db:studio": "pnpm --filter @wms/db db:studio"
  },
  "devDependencies": {
    "turbo": "^2.1.0",
    "typescript": "^5.6.0",
    "prettier": "^3.3.0"
  },
  "engines": {
    "node": ">=20"
  },
  "pnpm": {
    "overrides": {
      "@types/react": "^19.0.0",
      "@types/react-dom": "^19.0.0"
    },
    "peerDependencyRules": {
      "ignoreMissing": ["react", "react-dom", "@types/react", "@types/react-dom", "utf-8-validate", "expo-linking"]
    }
  }
}
